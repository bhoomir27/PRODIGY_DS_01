import pandas as pd
import matplotlib.pyplot as plt

# Load the CSV dataset
file_path = "API_SP.POP.TOTL_DS2_en_csv_v2_38144.csv"

# Read dataset while skipping metadata rows
df = pd.read_csv(file_path, skiprows=4)

# Select numeric year columns
numeric_cols = df.select_dtypes(include=['number']).columns.tolist()

# Keep only year columns
year_cols = [col for col in numeric_cols if str(col).isdigit()]

# Select latest year column
selected_col = year_cols[-1]

# Extract population data and remove missing values
data = df[selected_col].dropna()

# Create figure
plt.figure(figsize=(10,6))

# Create histogram
counts, bins, patches = plt.hist(
    data,
    bins=20
)

# Create skewness curve
bin_centers = 0.5 * (bins[:-1] + bins[1:])

plt.plot(
    bin_centers,
    counts
)

# Add labels and title
plt.xlabel(f"Population in {selected_col}")
plt.ylabel("Frequency")
plt.title(f"Histogram with Skewness Curve ({selected_col})")
# Display graph
plt.show()
